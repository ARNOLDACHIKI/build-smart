// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String     @id @default(cuid())
  email          String     @unique
  password       String
  name           String?
  profilePicture String?
  phone          String?
  bio            String?
  company        String?
  registrationNo String?
  industry       String?
  location       String?
  role           UserRole   @default(USER)
  emailVerified  Boolean    @default(false)
  twoFactorEnabled Boolean  @default(false)
  subscriptionPlanKey String?
  subscriptionPlanName String?
  subscriptionBillingCycle String?
  subscriptionStatus SubscriptionStatus @default(INACTIVE)
  subscriptionActivatedAt DateTime?
  subscriptionExpiresAt DateTime?
  subscriptionLastPaymentId String?
  emailVerificationToken String?
  emailVerificationExpiry DateTime?
  emailVerificationSent DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  
  receivedInquiries Inquiry[] @relation("ReceivedInquiries")
  sentInquiries     Inquiry[] @relation("SentInquiries")
  assistantConversations AssistantConversation[]
  assistantTasks AssistantTask[]
  assistantMeetings AssistantMeeting[]
  teamMembers TeamMember[]
  marketplaceInquiries Inquiry[] @relation("MarketplaceInquiries")
  matchedInquiries Inquiry[] @relation("MatchedInquiries")
  professionalMatches Match[] @relation("ProfessionalMatches")
  notifications Notification[]
  projectsAsClient Project[] @relation("ProjectClient")
  projectsAsProfessional Project[] @relation("ProjectProfessional")
  sentChatMessages ChatMessage[] @relation("ChatMessageSender")
  receivedChatMessages ChatMessage[] @relation("ChatMessageReceiver")
  uploadedFiles FileAttachment[] @relation("FileAttachmentUploader")
  paymentTransactions PaymentTransaction[]

  @@map("users")
}

model TeamMember {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name      String
  email     String
  role      String
  projects  Int      @default(0)
  avatar    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId, createdAt])
  @@map("team_members")
}

model Inquiry {
  id          String        @id @default(cuid())
  title       String?
  description String?
  budget      String?
  location    String?
  category    String?
  createdById String?
  createdBy   User?         @relation("MarketplaceInquiries", fields: [createdById], references: [id], onDelete: SetNull)
  senderName  String
  senderEmail String
  senderPhone String?
  message     String
  senderUserId String?
  senderUser  User?         @relation("SentInquiries", fields: [senderUserId], references: [id], onDelete: SetNull)
  replyMessage String?
  senderViewedAt DateTime?
  recipientId String?
  recipient   User?         @relation("ReceivedInquiries", fields: [recipientId], references: [id], onDelete: SetNull)
  status      InquiryStatus @default(PENDING)
  marketplaceStatus MarketplaceInquiryStatus @default(OPEN)
  matchedProfessionalId String?
  matchedProfessional User? @relation("MatchedInquiries", fields: [matchedProfessionalId], references: [id], onDelete: SetNull)
  respondedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  matches     Match[]
  projects    Project[]

  @@map("inquiries")
}

model Match {
  id             String        @id @default(cuid())
  inquiryId      String
  inquiry        Inquiry       @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  professionalId String
  professional   User          @relation("ProfessionalMatches", fields: [professionalId], references: [id], onDelete: Cascade)
  status         MatchStatus   @default(PENDING)
  note           String?
  respondedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([inquiryId, professionalId])
  @@index([professionalId, status, createdAt])
  @@map("matches")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  metadata  Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([userId, readAt, createdAt])
  @@map("notifications")
}

model AssistantConversation {
  id            String                       @id @default(cuid())
  userId        String
  user          User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String                       @default("New chat")
  lastMessageAt DateTime                     @default(now())
  createdAt     DateTime                     @default(now())
  updatedAt     DateTime                     @updatedAt
  messages      AssistantConversationMessage[]

  @@index([userId, lastMessageAt])
  @@map("assistant_conversations")
}

model AssistantConversationMessage {
  id             String                @id @default(cuid())
  conversationId String
  conversation   AssistantConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           AssistantChatRole
  content        String
  createdAt      DateTime              @default(now())

  @@index([conversationId, createdAt])
  @@map("assistant_conversation_messages")
}

model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("platform_settings")
}

model AssistantTask {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  context   String?
  dueDate   DateTime?
  priority  String   @default("MEDIUM")
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status, dueDate])
  @@map("assistant_tasks")
}

model AssistantMeeting {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  participant  String
  purpose      String
  scheduledFor DateTime
  status       String   @default("SCHEDULED")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId, scheduledFor, status])
  @@map("assistant_meetings")
}

model CommunityPost {
  id         String   @id @default(cuid())
  title      String
  summary    String
  content    String
  postType   String
  authorName String
  field      String
  interests  String[]
  isPublished Boolean @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isPublished, createdAt])
  @@map("community_posts")
}

model CommunityUpdate {
  id          String   @id @default(cuid())
  title       String
  body        String
  isPinned    Boolean  @default(false)
  isPublished Boolean  @default(true)
  pinnedAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished, isPinned, createdAt])
  @@map("community_updates")
}

model CommunityAd {
  id           String     @id @default(cuid())
  title        String
  copy         String
  ctaUrl       String
  targetFields String[]
  targetRoles  UserRole[]
  isApproved   Boolean    @default(false)
  approvedAt   DateTime?
  approvedById String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([isApproved, createdAt])
  @@map("community_ads")
}

model CommunityPostReport {
  id         String   @id @default(cuid())
  postId     String
  reporterId String
  reason     String
  status     String   @default("OPEN")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([postId, status])
  @@index([reporterId, createdAt])
  @@map("community_post_reports")
}

model PaymentTransaction {
  id                 String        @id @default(cuid())
  userId             String?
  user               User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  payerName          String
  payerEmail         String?
  phoneNumber        String
  planKey            String
  planName           String
  billingCycle       String
  amount             Int
  currency           String        @default("KES")
  status             PaymentStatus  @default(PENDING)
  merchantRequestId  String?
  checkoutRequestId  String?
  mpesaReceiptNumber String?
  resultCode         Int?
  resultDescription  String?
  callbackPayload    Json?
  requestPayload     Json?
  responsePayload    Json?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  completedAt        DateTime?

  @@index([checkoutRequestId])
  @@index([merchantRequestId])
  @@index([phoneNumber, createdAt])
  @@index([status, createdAt])
  @@map("payment_transactions")
}

enum UserRole {
  USER
  ADMIN
  ENGINEER
  LABOURER
  CEMENT_SUPPLIER
  GENERAL_SUPPLIER
  DEVELOPER
  FINANCIER
  CONTRACTOR
  REAL_ESTATE
  CONSULTANT
  TENANT
  PROJECT_MANAGER
  REGULATOR
  LOCAL_STAKEHOLDER
}

enum InquiryStatus {
  PENDING
  READ
  REPLIED
}

enum MarketplaceInquiryStatus {
  OPEN
  MATCHED
  CLOSED
}

enum MatchStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum NotificationType {
  INQUIRY_RESPONSE
  MATCH_CREATED
  AI_INQUIRY_DRAFT
  MILESTONE_CREATED
  MILESTONE_DUE_REMINDER
  MILESTONE_COMPLETED
  PROJECT_CREATED
  PROJECT_COMPLETED
  CHAT_MESSAGE
  FILE_UPLOADED
  COMMUNITY_POST_CREATED
}

enum AssistantChatRole {
  USER
  ASSISTANT
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  REQUESTED
  COMPLETED
  FAILED
}

enum SubscriptionStatus {
  INACTIVE
  ACTIVE
  EXPIRED
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model Project {
  id              String        @id @default(cuid())
  title           String
  description     String?
  clientId        String
  client          User          @relation("ProjectClient", fields: [clientId], references: [id], onDelete: Cascade)
  professionalId  String
  professional    User          @relation("ProjectProfessional", fields: [professionalId], references: [id], onDelete: Cascade)
  inquiryId       String?
  inquiry         Inquiry?      @relation(fields: [inquiryId], references: [id], onDelete: SetNull)
  budget          String?
  location        String?
  status          ProjectStatus @default(PLANNING)
  progress        Int           @default(0)
  startDate       DateTime?
  endDate         DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  milestones      Milestone[]
  chatMessages    ChatMessage[]
  fileAttachments FileAttachment[]

  @@index([clientId, professionalId, status, createdAt])
  @@map("projects")
}

model Milestone {
  id          String            @id @default(cuid())
  projectId   String
  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueDate     DateTime
  status      MilestoneStatus   @default(PENDING)
  progress    Int               @default(0)
  order       Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([projectId, status, dueDate])
  @@map("milestones")
}

model ChatMessage {
  id          String         @id @default(cuid())
  senderId    String
  sender      User           @relation("ChatMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId  String?
  receiver    User?          @relation("ChatMessageReceiver", fields: [receiverId], references: [id], onDelete: SetNull)
  projectId   String?
  project     Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  message     String
  timestamp   DateTime       @default(now())
  readAt      DateTime?

  attachments FileAttachment[]

  @@index([projectId, timestamp])
  @@index([senderId, receiverId, timestamp])
  @@map("chat_messages")
}

model FileAttachment {
  id          String       @id @default(cuid())
  uploadedById String
  uploadedBy  User         @relation("FileAttachmentUploader", fields: [uploadedById], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messageId   String?
  message     ChatMessage? @relation(fields: [messageId], references: [id], onDelete: Cascade)
  fileUrl     String
  fileType    String
  fileName    String
  mimeType    String?
  fileSize    Int?
  createdAt   DateTime     @default(now())

  @@index([projectId, createdAt])
  @@index([messageId, createdAt])
  @@map("file_attachments")
}
