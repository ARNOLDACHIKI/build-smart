# Backend Environment Variables

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@ep-xxxxxxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Server
PORT=3000
NODE_ENV=development
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=7d

# CORS
FRONTEND_URL=http://localhost:8080

# Local LLM (Ollama)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1
OLLAMA_TIMEOUT_MS=90000

# Dev auth bypass (optional, useful when DB is unreachable)
DEV_AUTH_BYPASS=false
DEV_ENGINEER_EMAIL=engineer@local.test
DEV_ENGINEER_PASSWORD=Engineer1234
DEV_ENGINEER_NAME=Mock Engineer

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
